# Trading212 credentials
T212_API_KEY=your_api_key_here
T212_API_SECRET=your_api_secret_here
T212_MODE=demo          # "demo" or "live" — always start on demo!

# Telegram alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Instrument — T212 ticker and matching yfinance symbol
SYMBOL_T212=QQQ_US_EQ
SYMBOL_YF=QQQ

# Strategy
INTERVAL=1h             # candle interval: 1h recommended
EMA_FAST=20
EMA_SLOW=50
RSI_PERIOD=14
RSI_THRESHOLD=50        # RSI must be above this to go long

# Risk
RISK_PER_TRADE=0.01     # fraction of cash to risk per trade (1%)
MAX_DAILY_LOSS=0.03     # kill switch triggers at 3% daily drawdown
